APP_ENV=local
READ_ONLY_MODE=true

BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
FRONTEND_PORT=3000

DATABASE_URL=postgresql://market:market@postgres:5432/market
BINANCE_WS_BASE=wss://stream.binance.com:9443/stream
COINBASE_WS_URL=wss://ws-feed.exchange.coinbase.com
ENABLE_COINBASE=true
KRAKEN_WS_URL=wss://ws.kraken.com/v2
ENABLE_KRAKEN=false
BYBIT_SPOT_WS_URL=wss://stream.bybit.com/v5/public/spot
ENABLE_BYBIT=false
SYMBOLS=BTCUSDT,ETHUSDT,SOLUSDT
KLINE_INTERVALS=1m,5m
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
RETENTION_ENABLED=true
RETENTION_INTERVAL_SECONDS=3600
TRADES_RETENTION_DAYS=7
ORDER_BOOK_RETENTION_DAYS=1
CANDLES_RETENTION_DAYS=180
ANALYTICS_EVENTS_RETENTION_DAYS=30
ANALYTICS_SNAPSHOTS_RETENTION_DAYS=30
RETENTION_DELETE_LIMIT=10000
ORDER_BOOK_PERSIST_INTERVAL_MS=1000

NEXT_PUBLIC_BACKEND_HTTP_URL=http://localhost:8000
NEXT_PUBLIC_BACKEND_WS_URL=ws://localhost:8000/ws/market
